---
import ArchiveIcon from "@/components/ArchiveIcon.astro";
import HudPanel from "@/components/HudPanel.astro";
import StatusPill from "@/components/StatusPill.astro";
import TagCluster from "@/components/TagCluster.astro";
import type { ArchiveSection } from "@/data/sections";
import type { ArchiveEntryView } from "@/lib/archive";

type Props = {
  section: ArchiveSection;
  entries: ArchiveEntryView[];
};

const { section, entries } = Astro.props;
---

<HudPanel class="section-index-panel">
  <header class="overview-header">
    <p class="eyebrow">Archive Section</p>
    <h1>{section.label}</h1>
    <p>{section.description}</p>
  </header>

  <div class="entry-grid">
    {entries.map((entry) => (
      <a class="entry-card" href={entry.href}>
        <span class="entry-icon-frame"><ArchiveIcon name={section.icon} /></span>
        <div class="entry-card-meta">
          <StatusPill status={entry.status} />
          <span>{entry.lastUpdated}</span>
        </div>
        <h2>{entry.title}</h2>
        <p>{entry.summary}</p>
        <TagCluster tags={entry.tags.slice(0, 3)} />
      </a>
    ))}
  </div>
</HudPanel>
