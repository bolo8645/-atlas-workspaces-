---
import StatusPill from "@/components/StatusPill.astro";
import type { ArchiveEntryView } from "@/lib/archive";

type Props = {
  entry: ArchiveEntryView;
};

const { entry } = Astro.props;
const rows = [
  ["Category", entry.singularLabel],
  ["Affiliations", entry.affiliations.length > 0 ? entry.affiliations.join(", ") : "Sample Placeholder"],
  ["Last Updated", entry.lastUpdated],
  ["Source", "Archive Record"]
];
---

<section class="inspector-section">
  <div class="section-rule">
    <h3>Metadata</h3>
  </div>
  <dl class="metadata-table">
    <div>
      <dt>Status</dt>
      <dd><StatusPill status={entry.status} /></dd>
    </div>
    {rows.map(([label, value]) => (
      <div>
        <dt>{label}</dt>
        <dd>{value}</dd>
      </div>
    ))}
  </dl>
</section>
